---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Game developer, reverse engineer, and the founder of oink.industries — the number-one developer tool for Garry's Mod." } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-bg text-ink">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0a0908" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="grain min-h-screen overflow-x-hidden">
		<slot />
	</body>
</html>
