---
const links = [
	{ href: "#work", label: "Work" },
	{ href: "#about", label: "About" },
	{ href: "#contact", label: "Contact" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-bg/60 border-b border-[--color-stroke]">
	<nav class="mx-auto max-w-6xl px-6 h-16 flex items-center justify-between">
		<a href="#top" class="font-bold tracking-tight text-lg">
			<span class="text-accent">⌬</span> nsa.gov
		</a>
		<ul class="hidden md:flex items-center gap-8 text-sm text-ink-dim">
			{
				links.map((l) => (
					<li>
						<a href={l.href} class="hover:text-accent transition-colors duration-200">
							{l.label}
						</a>
					</li>
				))
			}
		</ul>
		<a
			href="#contact"
			class="hidden md:inline-block text-sm font-semibold px-4 py-2 rounded-full border border-accent/40 text-accent hover:bg-accent hover:text-bg transition-colors duration-200"
		>
			Get in touch
		</a>
	</nav>
</header>
