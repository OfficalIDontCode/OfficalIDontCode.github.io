---
const year = new Date().getFullYear();

const socials = [
	{ label: "X / Twitter", value: "_xeroxz", href: "https://x.com/_xeroxz" },
	{ label: "UnknownCheats", value: "idontcode", href: "https://www.unknowncheats.me/forum/members/3543704.html" },
];
---

<div class="border-t border-[--color-stroke]">
	<div class="px-6 max-w-6xl mx-auto py-10">
		<p class="font-mono text-xs text-accent tracking-widest mb-4">// FIND ME AS idontcode</p>
		<div class="flex flex-wrap gap-3">
			{socials.map((s) => (
				<a
					href={s.href}
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center gap-2 px-4 py-2 rounded-lg bg-bg-card border border-[--color-stroke] hover:border-accent/40 hover:text-accent transition text-sm text-ink-dim"
				>
					<span class="font-mono text-xs">{s.label}</span>
					<span class="text-ink text-xs">@{s.value}</span>
				</a>
			))}
		</div>
	</div>
</div>

<footer class="px-6 max-w-6xl mx-auto py-6 border-t border-[--color-stroke] flex flex-wrap items-center justify-between gap-4 text-sm text-ink-dim">
	<p class="font-mono">© {year} nsa.gov &mdash; built with astro + tailwind, hosted on github pages.</p>
	<a href="#top" class="hover:text-accent transition">Back to top ↑</a>
</footer>
