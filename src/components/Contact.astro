---
const channels = [
	{ label: "Email", value: "jadenchris399@gmail.com", href: "mailto:jadenchris399@gmail.com" },
	{ label: "GitHub", value: "lynxcc121-cmyk", href: "https://github.com/lynxcc121-cmyk" },
	{ label: "Discord", value: "nsa.gov", href: "https://discord.com/users/nsa.gov" },
	{ label: "Roblox", value: "Primal Islands", href: "https://www.roblox.com/games/106754741049599" },
];
---

<section id="contact" class="px-6 max-w-6xl mx-auto py-24 md:py-32 border-t border-[--color-stroke]">
	<p class="font-mono text-sm text-accent mb-6 tracking-widest">// GET IN TOUCH</p>

	<h2 class="text-5xl md:text-7xl font-extrabold tracking-tight max-w-3xl leading-[1.05]">
		Building something hard? <span class="text-accent">Let's talk.</span>
	</h2>

	<p class="mt-8 text-lg md:text-xl text-ink-dim max-w-2xl leading-relaxed">
		Open to contract work on game engineering, anti-cheat, live-service tooling, and applied AI pipelines. Quick questions are welcome too.
	</p>

	<div class="mt-12 grid sm:grid-cols-2 gap-3 max-w-2xl">
		{
			channels.map((c) => (
				<a
					href={c.href}
					class="group flex items-center justify-between gap-4 px-5 py-4 rounded-xl bg-bg-card border border-[--color-stroke] hover:border-accent/40 transition"
				>
					<span class="text-sm font-mono text-ink-dim">{c.label}</span>
					<span class="text-ink group-hover:text-accent transition truncate">{c.value} →</span>
				</a>
			))
		}
	</div>
</section>
