---
const stack = {
	Games: ["roblox-ts", "Flamework", "@rbxts/react", "ProfileService", "Garry's Mod (GLua)"],
	"Languages": ["TypeScript", "Lua / GLua", "C", "C++", "x64 ASM", "Python"],
	"Web / tooling": ["Node", "Astro", "Tailwind", "Custom tooling"],
	Infra: ["MySQL", "Redis", "Stripe", "Roblox Open Cloud", "Discord bots / bridges"],
	"Reverse engineering": ["IDA", "Ghidra", "x86-64 / ARM64", "Frida", "API hooking"],
};
---

<section id="about" class="px-6 max-w-6xl mx-auto py-24 md:py-32 border-t border-[--color-stroke]">
	<div class="grid md:grid-cols-2 gap-12 md:gap-20">
		<div>
			<p class="font-mono text-sm text-accent mb-6 tracking-widest">// ABOUT</p>
			<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-8 leading-tight">
				Code, games, and the systems underneath.
			</h2>
			<div class="space-y-6 text-ink-dim leading-relaxed text-lg max-w-prose">
				<p>
					I'm a senior software engineer who spends most days at the boundary between game design and systems engineering &mdash; building the frameworks, anti-cheat, and tooling that let live multiplayer games stay live.
				</p>
				<p>
					Before this I cut my teeth on cybersecurity and reverse engineering. That perspective bleeds into everything I ship: I think about adversarial inputs, exploitability, and load characteristics before I think about features.
				</p>
				<p>
					I prefer small, sharp tools to bloated frameworks. Most of what I build is direct, terse, and refactor-friendly &mdash; if a piece of code wouldn't survive a code review, it doesn't ship.
				</p>
			</div>
		</div>

		<div>
			<p class="font-mono text-sm text-accent mb-6 tracking-widest">// STACK</p>
			<div class="space-y-6">
				{
					Object.entries(stack).map(([cat, items]) => (
						<div>
							<p class="text-sm font-semibold text-ink mb-2">{cat}</p>
							<div class="flex flex-wrap gap-2">
								{items.map((it) => (
									<span class="text-xs px-3 py-1 rounded-full bg-bg-card border border-[--color-stroke] text-ink-dim font-mono">
										{it}
									</span>
								))}
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>
